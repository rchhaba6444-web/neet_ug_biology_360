# NEET UG Biology 360 - Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration
DB_PATH=./neet.db

# JWT Secret Key (Generate a strong random string)
JWT_SECRET=neet_biology_360_jwt_secret_key_2024_secure_random_string_here_abcdefghijklmnopqrstuvwxyz1234567890

# Email Configuration (Gmail)
# Get App Password from: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here

# Admin Contact Details
ADMIN_EMAIL=kavirani576@gmail.com
ADMIN_PHONE=9513102159

# SMS Configuration (Fast2SMS - FREE 20 SMS/day on trial)
# Get API key from: https://www.fast2sms.com
FAST2SMS_API_KEY=your-fast2sms-api-key

# WhatsApp Configuration (CallMeBot - FREE)
# Get API key from: https://www.callmebot.com
CALLMEBOT_API_KEY=your-callmebot-api-key

# Razorpay Payment Gateway
# Get test keys from: https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Firebase Configuration (Optional - for advanced features)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
