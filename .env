# Environment Configuration for NEET UG Biology 360
# IMPORTANT: Keep this file secure and never commit it to version control

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=production

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_PATH=./neet.db

# ============================================
# JWT SECRET (CHANGE THIS TO A STRONG RANDOM STRING!)
# Generate one at: https://www.lastpass.com/features/password-generator
# ============================================
JWT_SECRET=neet_bio_360_secure_jwt_secret_2024_change_this_to_random_string

# ============================================
# ADMIN CONTACT (For notifications)
# ============================================
ADMIN_EMAIL=kavirani576@gmail.com
ADMIN_PHONE=9513102159

# ============================================
# EMAIL CONFIGURATION (Gmail)
# ============================================
# Step 1: Enable 2-Factor Authentication on your Gmail
# Step 2: Generate App Password at: https://myaccount.google.com/apppasswords
# Step 3: Copy the 16-character password below (no spaces)
EMAIL_USER=kavirani576@gmail.com
EMAIL_PASS=vnhojdcvqztyjgfe

# ============================================
# SMS CONFIGURATION (Fast2SMS - FREE 20 SMS/day)
# ============================================
# 1. Register at: https://www.fast2sms.com
# 2. Get API key from Dashboard
# 3. FREE plan gives 20 SMS/day (enough for testing)
FAST2SMS_API_KEY=JTFBwslOfhgZqIQE3o4yHd2j7pMnNK5kPD98YemaXv1Ucz0txrqdnlPTMkA380L9bfcwzoIeFa4t2Wi1

# ============================================
# WHATSAPP CONFIGURATION (CallMeBot - FREE)
# ============================================
# 1. Go to: https://www.callmebot.com/blog/free-api-whatsapp-messages/
# 2. Send message to +34 644 48 28 71 with "I allow callmebot to send me messages"
# 3. Get your API key from the reply
CALLMEBOT_API_KEY=your-callmebot-api-key

# ============================================
# FIREBASE CONFIGURATION (Google Login)
# ============================================
# Get these from: https://console.firebase.google.com > Project Settings > General
FIREBASE_API_KEY=your-firebase-api-key-here
FIREBASE_AUTH_DOMAIN=neet-biology-360.firebaseapp.com
FIREBASE_PROJECT_ID=neet-biology-360
FIREBASE_STORAGE_BUCKET=neet-biology-360.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
FIREBASE_APP_ID=your-firebase-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id

# ============================================
# RAZORPAY PAYMENT GATEWAY (India)
# ============================================
# 1. Register at: https://dashboard.razorpay.com/signup
# 2. Complete KYC verification
# 3. Get Test Keys from Settings > API Keys
# 4. For production, switch to Live Keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
NODB_UPDATE=true
