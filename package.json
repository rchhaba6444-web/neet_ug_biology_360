{
  "name": "neet-backend",
  "version": "1.0.0",
  "description": "Backend server for NEET preparation platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "security-check": "npm audit",
    "setup": "cp .env.example .env && echo 'Please edit .env file with your configuration'",
    "test-deployment": "node -e 'console.log(\"Node.js version:\", process.version); console.log(\"Platform:\", process.platform); console.log(\"Arch:\", process.arch); require(\"./database.js\")'"
  },
  "dependencies": {
    "axios": "^1.13.5",
