    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "fast2sms": "^1.0.3",
    "firebase": "^12.10.0",
    "form-data": "^4.0.5",
    "fs-extra": "^11.3.3",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "razorpay": "^2.9.6",
    "sqlite3": "^5.0.2",
